    collectedTime: 0
  - id: incense
    name: "\u3010\u4E00\u5305\u796D\u62DC\u7528\u7684\u9999\u8DDF\u4F7F\u7528\u6307\u5357\u3011"
    detail: "\u9999\u7684\u6578\u91CF\uFF0C\u4E0D\u53EA\u662F\u79AE\u7BC0\u2026\u2026\u60F3\u60F3\u4F60\u5728\u7948\u6C42\u6642\uFF0C\u5FC3\u88E1\u771F\u6B63\u6E34\u671B\u7684\u6771\u897F\u2014\u2014\u662F\u5E73\u5B89\uFF1F\u662F\u529B\u91CF\uFF1F\u9084\u662F\u2026\u2026\u4E00\u500B\u88AB\u7406\u89E3\u7684\u81EA\u5DF1"
    fullContent: 
    pages:
    - "\u3010\u4E00\u70B7\u9999\u3011                                    \u300C\u62DC\u62DC\u6642\u53EA\u7528\u4E00\u652F\u9999\u4EE3\u8868\u7684\u6DB5\u7FA9\u662F
      \u201C\u4E00\u5FC3\u4E00\u610F\u201D\uFF0C\u9069\u5408\u7528\u65BC\u65E5\u5E38\u796D\u62DC\u795E\u660E\u4F7F\u7528\uFF0C\u5411\u795E\u660E\u8ACB\u5B89\u300D"
    - "\u3010\u4E09\u70B7\u9999\u3011                                    \u300C\u62DC\u62DC\u6642\u4F7F\u7528\u4E09\u652F\u9999\u8C61\u5FB5\u8457
      \u201C\u5929\u3001\u5730\u3001\u4EBA\u201D \u4E09\u624D\uFF0C\u6216\u662F\u201C\u4F5B\u3001\u6CD5\u3001\u50E7\u201D\u4E09\u5BF6\uFF0C\u4E09\u5BF6\u9999\u9053\u6559\u53C8\u540D
      \u201C\u4E09\u6E05\u9999\u201D\u6B64\u4E09\u6E05\u70BA\u7389\u6E05\u539F\u59CB\u5929\u5C0A\uFF0C\u4E0A\u6E05\u9748\u5BF6\u5929\u5C0A\uFF0C\u592A\u6E05\u9053\u5FB7\u5929\u5C0A\uFF0C\u4E00\u822C\u662F\u7528\u4F86\u4F9B\u795E\u3001\u53EC\u4EA1\u8FD4\u9B42\u7B49\uFF0C\u901A\u5E38\u70BA\u6709\u4E8B\u7A1F\u5831\u3001\u7948\u6C42\u3001\u61C7\u6C42\u4E4B\u610F\u300D"
    - "\u3010\u4E94\u70B7\u9999\u3011                                     \u300C\u62DC\u62DC\u6642\u4F7F\u7528\u4E94\u652F\u9999\u70BA\u201C\u5929\u5730\u4E94\u884C\u9999\u201D\uFF0C\u53C8\u540D\u201C\u9670\u967D\u4E94\u884C\u9999\u201D\u7528\u4F86\u796D\u62DC\u6771\u3001\u897F\u3001\u5357\u3001\u5317\u3001\u4E2D\u4E94\u65B9\u795E\u9748\uFF0C\u4E2D\u5BAE\u70BA\u6559\u4E3B\u9999\uFF0C\u6771\u5BAE\u9752\u9F8D\u9999\uFF0C\u897F\u5BAE\u767D\u864E\u9999\uFF0C\u5317\u5BAE\u7384\u6B66\u9999\uFF0C\u5357\u5BAE\u6731\u96C0\u9999\uFF0C\u4E94\u5BAE\u53C8\u5206\u5225\u5C0D\u61C9\u8457\u4E94\u884C\u5C6C\u6027\u91D1\u3001\u6728\u3001\u6C34\u3001\u706B\u3001\u571F\uFF0C\u5927\u591A\u7528\u65BC\u796D\u62DC\u4E00\u4E9B\u91CD\u5927\u7684\u7BC0\u65E5\u6216\u662F\u6BD4\u8F03\u9686\u91CD\u7684\u6CD5\u6703\u7B49\uFF0C\u5411\u795E\u660E\u8ABF\u501F\u4E94\u71DF\u300D"
    - "\u3010\u4E03\u70B7\u9999\u3011                     \u300C\u62DC\u62DC\u6642\u4F7F\u7528\u4E03\u652F\u9999\u4EE3\u8868\u7684\u662F\u201C\u5317\u6597\u4E03\u661F\u9999\u201D\uFF0C\u4E3B\u8981\u7528\u65BC\u53EC\u8ACB\u5929\u795E\u3001\u5929\u5175\u3001\u5929\u5C07\uFF0C\u5411\u795E\u660E\u7948\u6C42\u8ABF\u8F49\u751F\u6B7B\u6216\u547D\u904B\u8D70\u5411\uFF0C\u4E0D\u5230\u842C\u4E0D\u5F97\u5DF2\uFF0C\u5207\u52FF\u4F7F\u7528\u300D"
    - "\u3010\u4E5D\u70B7\u9999\u3011                     \u300C\u62DC\u62DC\u6642\u4F7F\u7528\u4E5D\u652F\u9999\u4EE3\u8868\u201C\u6771\u65B9\u81F3\u9AD8\u7121\u4E0A\u7684\u795E\u660E\u7389\u7687\u5927\u5E1D\u201D\uFF0C\u201C\u4E5D\u201D\u70BA\u967D\u6578\u7684\u6975\u81F4\uFF0C\u4E5D\u67F1\u9999\u70BA\u4E5D\u4E5D\u9023\u74B0\u9999\uFF0C\u4E0A\u901A\u4E09\u5341\u4E09\u5929\uFF0C\u4E0B\u9054\u4E09\u5341\u4E09\u5730\uFF0C\u9EDE\u71C3\u904E\u5F8C\u4E0A\u8ACB\u7389\u7687\u5927\u5E1D\uFF0C\u4E0B\u8ACB\u5341\u6BBF\u95BB\u7F85\uFF0C\u82E5\u975E\u800C\u4E0D\u5F97\u5DF2\uFF0C\u6C42\u52A9\u7121\u9580\uFF0C\u4EBA\u529B\u518D\u4E5F\u4E0D\u80FD\u633D\u56DE\uFF0C\u5E0C\u671B\u7389\u7687\u5927\u5E1D\u5341\u6BBF\u95BB\u7F85\u9748\u7280\u84BC\u751F\uFF0C\u6551\u82E6\u6551\u96E3\u300D"
    collected: 0
