  - id: FamilyPortrait
    name: "\u3010\u5168\u5BB6\u798F\u3011"
    detail: "\u4E00\u5F35\u5168\u5BB6\u51FA\u904A\u6642\u7684\u5168\u5BB6\u798F\u7167\u7247\u3002\n\u7167\u7247\u4E3B\u8981\u7684\u529F\u80FD\u5C31\u662F\u5C07\u8A18\u61B6\u6355\u6349\u4E0B\u4F86\uFF0C\u8A18\u61B6\u88E1\u7684\u7B11\u5BB9\u5728\u90A3\u4E00\u523B...\u662F\u771F\u5BE6\u7684\u3002"
    fullContent: "\u4E00\u5F35\u5168\u5BB6\u51FA\u904A\u6642\u7684\u5168\u5BB6\u798F\u7167\u7247\u3002\n\u7167\u7247\u4E3B\u8981\u7684\u529F\u80FD\u5C31\u662F\u5C07\u8A18\u61B6\u6355\u6349\u4E0B\u4F86\uFF0C\u8A18\u61B6\u88E1\u7684\u7B11\u5BB9\u5728\u90A3\u4E00\u523B...\u662F\u771F\u5BE6\u7684\u3002"
