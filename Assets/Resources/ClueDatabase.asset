  - id: Agreement
    name: "\u3010\u96E2\u5A5A\u5354\u8B70\u66F8\u3011"
    detail: "\u4E00\u5F35\u5DF2\u7D93\u7C3D\u7F72\u4E86\u5ABD\u5ABD\u540D\u5B57\u8DDF\u8CC7\u6599\uFF0C\u4F46\u53E6\u4E00\u65B9\u9084\u672A\u7C3D\u5B57\u7684\u96E2\u5A5A\u5354\u8B70\u66F8\u3002\u5ABD\u5ABD\u6700\u7D42\u9084\u662F\u6C92\u8FA6\u6CD5\u5FCD\u53D7\u7238\u7238\u9078\u64C7\u96E2\u5A5A\uFF0C\u6211\u60F3\u5979\u61C9\u8A72\u4E5F\u662F\u7D93\u904E\u4E86\u518D\u4E09\u7684\u8003\u616E\u624D\u505A\u4E86\u9019\u500B\u6C7A\u5B9A\u5427\uFF1F"
    fullContent: 
