  - id: Senior_letter
    name: "\u3010\u5B78\u59D0\u7684\u4FE1\u3011"
    detail: "\u4E00\u5F35\u5B78\u59CA\u907A\u7559\u7684\u4FE1\u4EF6\uFF0C\u4E0A\u9762\u6EFF\u6EFF\u90FD\u662F\u5979\u5C0D\u201C\u5B83\u201D\u7684\u53AD\u60E1\uFF0C\u660E\u660E\u5BE6\u73FE\u4E86\u5979\u7684\u5FC3\u9858\uFF0C\u537B\u628A\u5979\u6C38\u9060\u95DC\u8D77\u4F86\u3002\u770B\u6A23\u5B50\u9019\u500B\u201C\u5B83\u201D\u8AAA\u7684\u8A71\u6839\u672C\u4E0D\u80FD\u4FE1\u3002"
    fullContent: "\u201C\u5B83\u201D\u5BE6\u73FE\u4E86\u6211\u7684\u9858\u671B\uFF0C\u4F46\u4E4B\u5F8C\u6211\u5C31\u88AB\u56F0\u5728\u9019\u500B\u8A72\u6B7B\u7684\u5730\u65B9\u2026\u2026\u7B49\u6211\u96E2\u958B\u9019\u88E1\uFF0C\u6211\u4E00\u5B9A\u8981\u63ED\u7A7F\u201C\u5B83\u201D\u7684\u8B0A\u8A00\u2026\u2026\u4F46\u6211\u7684\u56DB\u80A2\u537B\u6C92\u6709\u8FA6\u6CD5\u52D5\u5F48\uFF0C\u6703\u6709\u4EBA\u4F86\u6551\u6211\u55CE\uFF1F\u6211\u9084\u4E0D\u60F3\u6B7B\u2026\u2026"
