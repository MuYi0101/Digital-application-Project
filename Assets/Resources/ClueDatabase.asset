  clues:
  - id: Letter
    name: "\u3010\u4E00\u5C01\u8001\u820A\u7684\u4FE1\u5C01\u3011"
    detail: "\u4E00\u5C01\u8001\u820A\u7684\u4FE1\u5C01\uFF0C\u4FE1\u5C01\u888B\u88E1\u9762\u653E\u8457\u4E00\u5F35\u5B57\u8DE1\u6F66\u8349\u3001\u5B57\u88E1\u884C\u9593\u9084\u53C3\u96DC\u8457\u6CE8\u97F3\u7684\u4FE1\u4EF6\uFF0C\u662F\u4E03\u6B72\u7684\u58A8\u6D85\u5BEB\u7D66\u672A\u4F86\u81EA\u5DF1\u7684\u4FE1\u3002\r\n"
    fullContent: "\u300C\u7D6616\u3119\u3128\u311F\u02CB\u7684\u58A8\u6D85\uFF0C16\u6B72\u7684\u6211\uFF0C\u4F60\u904E\u5F97\u597D\u55CE\uFF1F\u4F60\u662F\u4E0D\u662F\u5B78\u6703\u4E86\u6211\u4E00\u76F4\u60F3\u5B78\u7684\u310D\u3124\u3111\u4E00\u3123\u02CA\uFF08\u92FC\u7434\uFF09\uFF1F\u9084\u662F\u4F60\u7684\u310F\u3128\u311A\u02CB\uFF08\u756B\uFF09\u88AB\u5C55\u310C\u3122\u02C7\uFF08\u89A7\uFF09\u5728\u3105\u311B\u02CA\uFF08\u535A\uFF09\u7269\u310D\u3128\u3122\u02C7\uFF08\u9928\uFF09\uFF1F\u4F60\u4E00\u5B9A\u5F88\u310C\u3127\u02CB\uFF08\u53B2\uFF09\u5BB3\u3109\u3128\u311F\u02CB\uFF08\u5C0D\uFF09\u4E0D\u3109\u3128\u311F\u02CB\uFF08\u5C0D\uFF09\uFF0C\u6211\u597D\u5E0C\u671B\u80FD\u5FEB\u3109\u3127\u3122\u02C7\uFF08\u9EDE\uFF09\u9577\u5927\r\n7\u6B72\u7684\u58A8\u6D85\u3110\u3127\u3125\u02CB\uFF08\u656C\uFF09\u4E0A\u300D\r\n"
    pages: []
    collected: 1
    collectedTime: 30.45012
  - id: NPC_talk
    name: "\u3010\u6728\u5076\u7684\u5C0D\u8A71\u3011"
    detail: "\u5169\u500B\u6728\u5076\u7684\u5C0D\u8A71\uFF0C\u8B1B\u8FF0\u8457\u7576\u540C\u5B78\u5011\u5C0D\u65BC\u5FC3\u7406\u75BE\u75C5\u7684\u6392\u65A5\u4EE5\u53CA\u540C\u5B78\u5011\u7684\u60E1\u8A00\u60E1\u8A9E\u3002"
    fullContent: "\u6728\u5076A\uFF1A\u300C\u6B38\u6B38\uFF01\u4F60\u77E5\u9053B\u73ED\u7684\u90A3\u500B\u795E\u7D93\u75C5\u55CE\uFF1F\u300D\r\n\u6728\u5076B\uFF1A\u300C\u6211\u597D\u50CF\u77E5\u9053\uFF01\u6211\u8A18\u5F97\u4ED6...\u59D3\u4EC0\u9EBC\u4F86\u8457\uFF1F\u6211\u60F3\u4E00\u4E0B......\u5594\uFF01\u597D\u50CF\u662F\u59D3...\u58A8\uFF1F\u300D\r\n\u6728\u5076A\uFF1A\u300C\u5594\u5C0D\u5C0D\u5C0D\uFF01\u807D\u8AAA\u4ED6\u597D\u50CF\u6709\u7CBE\u795E\u75BE\u75C5\u7684\u6A23\u5B50\uFF01\u300D\r\n\u6728\u5076B\uFF1A\u300C\u771F\u7684\u5047\u7684\uFF1F\u96E3\u602A\uFF01\u6211\u4E0A\u6B21\u597D\u50CF\u6709\u770B\u5230\u4ED6\u5728\u5403\u85E5\u300D\r\n\u6728\u5076A\uFF1A\u300C\u4EE5\u5F8C\u9047\u5230\u4ED6\u8981\u5C0F\u5FC3\u4E00\u9EDE\uFF0C\u514D\u5F97\u4ED6\u54EA\u5929\u4E00\u767C\u75C5\u5C31\u653B\u64CA\u4EBA\u300D\r\n\u6728\u5076B\uFF1A\u300C\u5929\u554A\uFF0C\u50BBX\u5B78\u6821\u70BA\u4EC0\u9EBC\u4E0D\u958B\u9664\u4ED6\uFF1F\u8B93\u6211\u5011\u9019\u4E9B\u666E\u901A\u4EBA\u8DDF\u96A8\u6642\u90FD\u6709\u53EF\u80FD\u6703\u653B\u64CA\u6211\u5011\u7684\u795E\u7D93\u75C5\u5F85\u5728\u4E00\u8D77\uFF1F\u300D\r\n"
    pages: []
    collected: 1
    collectedTime: 30.45012
  - id: Journal
    name: "\u3010\u6709\u9EDE\u820A\u7684\u65E5\u8A18\u672C\u3011"
    detail: "\u96F6\u788E\u7684\u65E5\u8A18\u5167\u5BB9\uFF0C\u88E1\u9762\u8A18\u9304\u4E86\u8A31\u591A\u4F5C\u8005\u7D93\u6B77\u7684\u5927\u5C0F\u4E8B\uFF0C\u4E0D\u904E\u5F8C\u534A\u6BB5\u5BEB\u7684\u5E7E\u4E4E\u90FD\u662F\u8CA0\u9762\u7684\u5167\u5BB9\uFF0C\u770B\u8D77\u4F86\u4F3C\u4E4E\u6C92\u6709\u904E\u5F97\u5F88\u9806\u9042\u3002"
    fullContent: 
    pages:
    - "2003\u5E749\u670811\u65E5\uFF08\u56DB\uFF09 \u4ECA\u5929\u662F\u4E2D\u79CB\u7BC0\uFF0C\u5ABD\u5ABD\u5E36\u8457\u6211\u5230\u963F\u59E8\u5BB6\u70E4\u8089\u3002\u70AD\u706B\u7684\u9999\u5473\u3001\u6ECB\u6ECB\u4F5C\u97FF\u7684\u8089\u7247\u8072\uFF0C\u8B93\u6211\u60F3\u8D77\u5C0F\u6642\u5019\u7684\u5718\u805A\u6642\u5149\u3002\u90A3\u6642\uFF0C\u7238\u7238\u3001\u5ABD\u5ABD\u3001\u963F\u59E8\u3001\u53D4\u53D4\u5011\u570D\u5728\u7210\u65C1\uFF0C\u4E00\u908A\u70E4\u4E00\u908A\u804A\u5929\uFF0C\u4F46\u8FD1\u5E7E\u5E74\u7238\u7238\u5C31\u518D\u4E5F\u6C92\u8DDF\u6211\u5011\u4E00\u8D77\u70E4\u8089\u4E86\u3002
      \u4ECA\u5E74\uFF0C\u7238\u7238\u4F9D\u820A\u6C92\u6709\u548C\u6211\u5011\u4E00\u8D77\u70E4\u8089\u3002\u770B\u8457\u7A7A\u4E0B\u4F86\u7684\u4F4D\u7F6E\uFF0C\u6211\u5FCD\u4E0D\u4F4F\u61F7\u5FF5\u904E\u53BB\u90A3\u6BB5\u4E00\u5BB6\u4EBA\u9F4A\u805A\u7684\u6EAB\u6696\u6642\u5149\u3002 "
    - "2004\u5E741\u670823\u65E5\uFF08\u4E94\uFF09 \u4ECA\u5929\u662F\u5927\u5E74\u521D\u4E8C\u4E5F\u662F\u6211\u7684\u751F\u65E5\uFF0C\u53EF\u662F\u6211\u537B\u4E00\u9EDE\u60F3\u6176\u795D\u7684\u5FC3\u60C5\u90FD\u6C92\u6709\uFF0C\u9019\u5B78\u671F\u7684\u671F\u672B\u8003\u53C8\u8003\u7838\u4E86\uFF0C\u518D\u904E\u4E0D\u4E45\u5C31\u8981\u8003\u9AD8\u4E2D\u4E86\uFF0C\u8981\u662F\u6C92\u6709\u8003\u5230\u597D\u5B78\u6821\uFF0C\u4E00\u5B9A\u53C8\u6703\u88AB\u7238\u5ABD\u7F75\u7684\u3002 "
    - "2004\u5E744\u670826\u65E5\uFF08\u4E00\uFF09 \u5927\u8003\u5C07\u81F3\uFF0C\u53EA\u5269\u4E0B\u4E0D\u5230\u4E00\u500B\u6708\u7684\u6642\u9593\uFF0C\u4ECA\u5929\u6211\u53C8\u88AB\u7238\u7238\u5ABD\u5ABD\u5538\u4E86\uFF0C\u56E0\u70BA\u671F\u4E2D\u8003\u7684\u6210\u7E3E\u975E\u5E38\u4E0D\u7406\u60F3\uFF0C\u6216\u8A31\u5C0D\u4ED6\u5011\u4F86\u8AAA\uFF0C\u6211\u5C31\u662F\u500B\u4E0D\u6210\u6750\u7684\u5B69\u5B50\uFF0C\u6C38\u9060\u6BD4\u4E0D\u4E0A\u5225\u4EBA\u2026\u8AAA\u51FA\u4F86\u53EA\u6703\u8B93\u5225\u4EBA\u5BB6\u7B11\u7684\u5B58\u5728\u3002
      \u5ABD\u5ABD\u73FE\u5728\u53C8\u5728\u8B1B\u96FB\u8A71\u4E86\uFF0C\u4E0D\u7528\u807D\u4E5F\u77E5\u9053\u5728\u8B1B\u4EC0\u9EBC\u3002 "
    - "2004\u5E747\u670810\u65E5\uFF08\u516D\uFF09 \u4ECA\u5929\u8003\u8A66\u7684\u5206\u767C\u7D50\u679C\u51FA\u4F86\u4E86\uFF0C\u8003\u4E86\u9593\u4E0D\u600E\u9EBC\u6A23\u7684\u9AD8\u4E2D\uFF0C\u4E0D\u610F\u5916\u7684\u53C8\u88AB\u7238\u7238\u5ABD\u5ABD\u5538\u4E86\u597D\u5E7E\u500B\u5C0F\u6642\uFF0C\u6211\u52AA\u529B\u904E\u4E86\uFF0C\u4F46\u6211\u771F\u7684\u6C92\u6709\u50CF\u5225\u4EBA\u4E00\u6A23\u6709\u90A3\u9EBC\u597D\u7684\u8CC7\u8CEA\u3002 "
    - "2004\u5E7410\u67086\u65E5\uFF08\u4E09\uFF09 \u5DF2\u7D93\u958B\u5B78\u4E00\u6BB5\u6642\u9593\u4E86\uFF0C\u4F46\u6211\u5728\u73ED\u4E0A\u9084\u662F\u6C92\u6709\u4EFB\u4F55\u670B\u53CB\uFF0C\u5230\u5E95\u70BA\u4EC0\u9EBC\uFF1F "
    - "2005\u5E742\u67087\u65E5\uFF08\u4E00\uFF09 \u6211\u5F88\u958B\u5FC3\uFF0C\u56E0\u70BA\u6628\u5929\u7D42\u65BC\u6709\u500B\u4EBA\u4F86\u627E\u6211\u8AAA\u8A71\u4E86\uFF0C\u662F\u4E00\u500B\u71B1\u60C5\u53C8\u958B\u6717\u7684\u7537\u751F\uFF0C\u4ED6\u53EB
      \u201C\u4ED5\u8C6A\u201D\uFF0C\u4ED6\u4EBA\u5F88\u597D\u804A\uFF0C\u8DDF\u4ED6\u5728\u4E00\u8D77\u4E5F\u8B93\u6211\u9019\u7121\u8DA3\u7684\u9AD8\u4E2D\u751F\u6D3B\u591A\u4E86\u90A3\u9EBC\u4E00\u9EDE\u7684\u8B8A\u5316\u3002 "
    - "2005\u5E745\u670811\u65E5\uFF08\u4E09\uFF09 \u6211\u4ECA\u5929\u7684\u5FC3\u60C5\u975E\u5E38\u5DEE\uFF0C\u4ED5\u8C6A\u8DDF\u6211\u5766\u767D\u4ED6\u7576\u521D\u6703\u8DDF\u6211\u642D\u8A71\uFF0C\u53EA\u662F\u56E0\u70BA\u4ED6\u8DDF\u670B\u53CB\u6253\u8CED\u8F38\u4E86\u624D\u6703\u4E3B\u52D5\u4F86\u627E\u6211\u804A\u5929\uFF0C\u770B\u8457\u4ED6\u90A3\u7FA4\u6240\u8B02\u7684
      \u201C\u670B\u53CB\u201D \u7528\u8457\u6232\u8B14\u7684\u8868\u60C5\u770B\u8457\u6211\uFF0C\u5C31\u8B93\u6211\u89BA\u5F97\u5641\u5FC3\uFF0C\u5728\u4ED6\u5011\u773C\u88E1\uFF0C\u6211\u53EA\u662F\u500B\u4ED6\u5011\u5A1B\u6A02\u7528\u7684\u5DE5\u5177\u4EBA\u800C\u5DF2\uFF0C\u597D\u5E0C\u671B\u4ED6\u5011\u90FD\u6D88\u5931\u3002 "
    - "2005\u5E748\u67088\u65E5\uFF08\u4E00\uFF09 \u4ECA\u5929\u6211\u60F3\u8D81\u6211\u53BB\u88DC\u7FD2\u7684\u6642\u9593\u5077\u5077\u53BB\u5B78\u6821\u7684\u5F8C\u5C71\u770B\u770B\u662F\u4E0D\u662F\u6709\u50B3\u8AAA\u4E2D\u7684\u9670\u5EDF\uFF0C\u6211\u6709\u4E8B\u60F3\u62DC\u8A17\u7942\u5E6B\u5FD9\uFF0C\u5E0C\u671B\u4E00\u5207\u9806\u5229\u3002 "
    - "2005\u5E746\u670819\u65E5\uFF08\u65E5\uFF09 \u524D\u5E7E\u5929\u6211\u5077\u5077\u807D\u5230\u73ED\u4E0A\u6709\u540C\u5B78\u5728\u8A0E\u8AD6\u9670\u5EDF\u7684\u4E8B\u60C5\uFF0C\u807D\u8AAA\u51E1\u662F\u53BB\u8A31\u9858\u7684\u4EBA\u9858\u671B\u90FD\u80FD\u6210\u771F\uFF1F
      \u7E3D\u611F\u89BA\u6709\u9EDE\u602A\u602A\u7684\uFF0C\u9670\u5EDF...\u4E0D\u90FD\u662F\u4F9B\u990A\u5B64\u9B42\u91CE\u9B3C\u7684\u55CE\uFF1F\u8DDF\u9019\u4E9B\u4F3C\u795E\u975E\u795E\u7684\u6771\u897F\u8A31\u9858\uFF0C\u9858\u671B\u771F\u7684\u80FD\u5920\u5BE6\u73FE\u55CE\uFF1F "
    collected: 1
    collectedTime: 30.45012
  - id: Journal1
    name: "\u3010\u65E5\u8A18\u6B98\u9801-1\u3011"
    detail: "\u653E\u5728\u6211\u7684\u623F\u9593\u88E1\u7684\u65E5\u8A18\uFF0C\u4E0A\u9762\u5BEB\u4E86\u5F88\u591A\u6211\u5F9E\u5C0F\u5230\u5927\u8DDF\u5BB6\u4EBA\u76F8\u8655\u4EE5\u53CA\u5728\u5BB6\u88E1\u767C\u751F\u7684\u4E8B\u60C5\uFF0C\u4F46\u6574\u9AD4\u4F86\u770B\u90FD\u633A\u8CA0\u9762\u7684\u3002"
    fullContent: 
    pages:
    - "1998\u5E741\u670827\u65E5\uFF08\u4E8C\uFF09  \u4ECA\u5929\u6211\u5F9E\u91AB\u9662\u56DE\u4F86\u5F8C\u627E\u4E0D\u5230\u591A\u591A\uFF0C\u5ABD\u5ABD\u8AAA\u591A\u591A\u8EAB\u4E0A\u5F88\u591A\u7D30\u83CC\uFF0C\u653E\u7260\u5728\u5BB6\u88E1\u4E82\u8DD1\u6703\u8B93\u6211\u5011\u90FD\u751F\u75C5\uFF0C\u6240\u4EE5\u624D\u628A\u7260\u9001\u8D70\uFF0C\u6211\u4E5F\u56E0\u6B64\u8DDF\u5ABD\u5ABD\u5435\u4E86\u4E00\u67B6\u3002 "
    - "1999\u5E744\u670816\u65E5\uFF08\u4E94\uFF09 \u4ECA\u5929\u6211\u5728\u5BA2\u5EF3\u5403\u9905\u4E7E\uFF0C\u5C0E\u81F4\u9905\u4E7E\u5C51\u6389\u5728\u6C99\u767C\u4E0A\uFF0C\u5ABD\u5ABD\u770B\u898B\u5F8C\u5F88\u751F\u6C23\u547D\u4EE4\u6211\u6E05\u4E7E\u6DE8\uFF0C\u9084\u898F\u5B9A\u4EE5\u5F8C\u5403\u6771\u897F\u53EA\u80FD\u5728\u9910\u684C\u4E0A\u3002 "
    - "2000\u5E748\u670818\u65E5\uFF08\u4E94\uFF09 \u4ECA\u5929\u56DE\u5230\u5BB6\u5F8C\u723A\u723A\u4E26\u6C92\u6709\u50CF\u4EE5\u524D\u4E00\u6A23\u51FA\u4F86\u8DDF\u6211\u6253\u62DB\u547C\uFF0C\u53CD\u800C\u5BB6\u88E1\u5230\u8655\u90FD\u627E\u4E0D\u5230\u723A\u723A\uFF0C\u7238\u7238\u8AAA\u662F\u723A\u723A\u81EA\u5DF1\u96E2\u958B\u7684\uFF0C\u56E0\u70BA\u4ED6\u73FE\u5728\u5E74\u7D00\u4E5F\u5927\u4E86\uFF0C\u6240\u4EE5\u8B93\u4ED6\u53BB\u990A\u8001\u9662\u8ACB\u8B77\u5DE5\u5E6B\u5FD9\u7167\u9867\u3002
      \u4E00\u60F3\u5230\u4EE5\u5F8C\u898B\u5230\u723A\u723A\u7684\u6A5F\u6703\u8D8A\u4F86\u8D8A\u5C11\u5C31\u89BA\u5F97\u597D\u96E3\u904E\uFF0C\u4F46\u7238\u7238\u537B\u7F75\u6211\u898B\u4E0D\u5230\u723A\u723A\u800C\u5DF2\uFF0C\u6709\u4EC0\u9EBC\u597D\u54ED\u7684\u3002 "
    - "2001\u5E7410\u670821\u65E5\uFF08\u65E5\uFF09 \u4ECA\u5929\u6BB5\u8003\u6210\u7E3E\u51FA\u4E86\uFF0C\u6211\u8003\u4E86\u7B2C\u4E5D\u540D\uFF0C\u5ABD\u5ABD\u5F88\u751F\u6C23\uFF0C\u4E00\u76F4\u5728\u8CAC\u5099\u6211\uFF0C\u628A\u6211\u7981\u8DB3\u5728\u623F\u9593\u5167\uFF0C\u53EB\u6211\u8B80\u66F8\uFF0C\u9084\u6C92\u6536\u4E86\u6211\u7684\u7E6A\u672C\uFF0C\u660E\u660E\u5ABD\u5ABD\u4EE5\u524D\u4E0D\u6703\u9019\u6A23\u7684...\u3002 "
