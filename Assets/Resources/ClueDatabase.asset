  - id: Letter2
    name: "\u3010\u4E00\u5C01\u5B57\u8DE1\u6F66\u8349\u7684\u66F8\u4FE1\u3011"
    detail: "\u4FE1\u5C01\u88E1\u7684\u4E00\u5B57\u4E00\u53E5\uFF0C\u90FD\u8A34\u8AAA\u8457\u7236\u89AA\u6C92\u8AAA\u51FA\u53E3\u7684\u771F\u76F8\u3002"
    fullContent: "\u8001\u9673\uFF1A\r\n\u6211\u7D42\u65BC\u628A\u90A3\u8001\u4E0D\u6B7B\u7684\u9001\u53BB\u990A\u8001\u9662\u4E86\uFF0C\r\n\u63A5\u4E0B\u4F86\u53EA\u8981\u7B49\u5230\u4ED6\u6B7B\u4E86\u4E4B\u5F8C\uFF0C\u6211\u5C31\u80FD\u62FF\u5230\u4ED6\u7684\u6240\u6709\u8CA1\u7522\uFF0C\r\n\u4F60\u5C31\u7B49\u8457\u6211\u6771\u5C71\u518D\u8D77\u7684\u90A3\u5929\u5230\u4F86\u5427\r"
    pages: []
    collected: 1
    collectedTime: 66.70165
  - id: dry_letter
    name: "\u3010\u4E00\u5C01\u8001\u820A\u7684\u4FE1\u5C01-2\u3011"
    detail: "\u5B57\u88E1\u884C\u9593\uFF0C\u4E0D\u53EA\u662F\u89E3\u91CB\u4E00\u4EF6\u4E8B\u3002\r\n\u90A3\u662F\u5979\u6C92\u6709\u5C0D\u4F60\u8AAA\u51FA\u53E3\u7684\u64D4\u5FC3\u2014\u2014\u53EA\u662F\uFF0C\u5979\u9078\u64C7\u4E86\u8B93\u4F60\u770B\u5230\u7D50\u679C\uFF0C\u800C\u4E0D\u662F\u7406\u7531\u3002\r\n"
    fullContent: "\u5B57\u88E1\u884C\u9593\uFF0C\u4E0D\u53EA\u662F\u89E3\u91CB\u4E00\u4EF6\u4E8B\u3002\r\n\u90A3\u662F\u5979\u6C92\u6709\u5C0D\u4F60\u8AAA\u51FA\u53E3\u7684\u64D4\u5FC3\u2014\u2014\u53EA\u662F\uFF0C\u5979\u9078\u64C7\u4E86\u8B93\u4F60\u770B\u5230\u7D50\u679C\uFF0C\u800C\u4E0D\u662F\u7406\u7531\u3002\r\n"
    pages:
    - "\u89AA\u611B\u7684\u59CA\u59CA\uFF1A \u3000\u3000\u6700\u8FD1\u6211\u5152\u5B50\u58A8\u6D85\u64BF\u4E86\u4E00\u96BB\u8C93\u54AA\u56DE\u5BB6\uFF0C\u4ED6\u53D6\u540D\u53EB\u591A\u591A\uFF0C\u554F\u6211\u53EF\u4E0D\u53EF\u4EE5\u990A\uFF0C\u4ED6\u597D\u50CF\u5F88\u559C\u6B61\u8C93\u54AA\uFF0C\u6211\u60F3\u8AAA\u8B93\u4ED6\u591A\u4E00\u500B\u966A\u4F34\uFF0C\u5C31\u990A\u4E86\u7260\u3002\u4F46\u662F\u6C92\u60F3\u5230\uFF0C\u5B69\u5B50\u5728\u63A5\u89F8\u8C93\u54AA\u5F8C\u5C0D\u8C93\u6BDB\u7522\u751F\u4E86\u56B4\u91CD\u7684\u904E\u654F\u53CD\u61C9\uFF0C\u4ED6\u51FA\u73FE\u4E86\u547C\u5438\u56F0\u96E3\u7684\u75C7\u72C0\uFF0C\u5FC5\u9808\u7DCA\u6025\u9001\u91AB\u3002\u91AB\u751F\u5F37\u70C8\u5EFA\u8B70\u6211\u5011\u4E0D\u80FD\u518D\u8B93\u5B69\u5B50\u63A5\u89F8\u8C93\u54AA\uFF0C\u5426\u5247\u53EF\u80FD\u6703\u6709\u751F\u547D\u5371\u96AA\u3002
      \u9019\u500B\u60C5\u6CC1\u8B93\u6211\u5F88\u4E0D\u6368\uFF0C\u4F46\u70BA\u4E86\u5B69\u5B50\u7684\u5065\u5EB7\uFF0C\u6211\u4E0D\u5F97\u4E0D\u5C07\u9019\u96BB\u5C0F\u8C93\u9001\u990A\u3002 "
    - "\u3000\u3000\u6211\u77E5\u9053\u4F60\u4E00\u76F4\u5F88\u559C\u6B61\u52D5\u7269\uFF0C\u4E5F\u6709\u76F8\u95DC\u7D93\u9A57\uFF0C\u4E0D\u77E5\u9053\u4F60\u662F\u5426\u80FD\u5E6B\u5FD9\u5C07\u7260\u9001\u990A\uFF0C\u6216\u8005\u5148\u5E6B\u5FD9\u7167\u9867\u4E00\u6BB5\u6642\u9593\uFF0C\u7B49\u627E\u5230\u5408\u9069\u7684\u65B0\u4E3B\u4EBA\u3002
      \u5C0F\u8C93\u5F88\u4E56\u3001\u5F88\u89AA\u4EBA\uFF0C\u6211\u771F\u7684\u5F88\u5E0C\u671B\u7260\u80FD\u627E\u5230\u4E00\u500B\u611B\u7260\u3001\u80FD\u597D\u597D\u7167\u9867\u7260\u7684\u5BB6\u3002 
      \u5982\u679C\u4F60\u9858\u610F\u5E6B\u5FD9\uFF0C\u6211\u6703\u628A\u5C0F\u8C93\u7684\u751F\u6D3B\u7528\u54C1\u4E00\u4F75\u9001\u904E\u53BB\uFF0C\u8B93\u7260\u5728\u65B0\u74B0\u5883\u80FD\u66F4\u5FEB\u9069\u61C9\u3002
      \u771F\u7684\u5F88\u62B1\u6B49\u8981\u7A81\u7136\u62DC\u8A17\u4F60\uFF0C\u4F46\u6211\u73FE\u5728\u5BE6\u5728\u6C92\u6709\u66F4\u597D\u7684\u8FA6\u6CD5\u3002
      \u8B1D\u8B1D\u4F60\u9858\u610F\u82B1\u6642\u9593\u95B1\u8B80\u9019\u5C01\u4FE1\uFF0C\u4E5F\u8B1D\u8B1D\u4F60\u4E00\u76F4\u4EE5\u4F86\u5C0D\u6211\u7684\u5E6B\u52A9\u3002         
      \u795D \u5E73\u5B89\u9806\u5FC3 \u4F60\u7684\u59B9\u59B9 1998 / 2 / 1 "
    collected: 1
    collectedTime: 284.96667
  - id: amulet
    name: "\u3010\u5E73\u5B89\u7B26\u3011"
    detail: "\u5ABD\u5ABD\u5728\u5C0F\u6642\u5019\u70BA\u6211\u6C42\u4F86\u7684\u4E00\u500B\u5E73\u5B89\u7B26\uFF0C\u4E0A\u9762\u5BEB\u8457\u300C\u4FDD\u4F51\u95D4\u5BB6\u5E73\u5B89\u300D\n\u5B83\u672C\u8A72\u662F\u5B88\u8B77\u6211\u7684\u7B26\u5492\u2026\u2026\u4E5F\u662F\u5ABD\u5ABD\u5C0D\u6211\u7684\u4FDD\u8B77\r\n\r"
    fullContent: "\u5ABD\u5ABD\u5728\u5C0F\u6642\u5019\u70BA\u6211\u6C42\u4F86\u7684\u4E00\u500B\u5E73\u5B89\u7B26\uFF0C\u4E0A\u9762\u5BEB\u8457\u300C\u4FDD\u4F51\u95D4\u5BB6\u5E73\u5B89\u300D\n\u5B83\u672C\u8A72\u662F\u5B88\u8B77\u6211\u7684\u7B26\u5492\uFF0C\u4E5F\u662F\u5ABD\u5ABD\u5C0D\u6211\u7684\u4FDD\u8B77\uFF0C\u4F46\u4E0A\u9762\u7684\u7070\u5875\u537B\u683C\u5916\u8AF7\u523A\r\n\r"
