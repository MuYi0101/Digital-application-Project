  - id: Journal4
    name: "\u3010\u65E5\u8A18\u6B98\u9801-4\u3011"
    detail: "\u5728\u6D17\u8863\u9593\u5236\u670D\u5916\u5957\u88E1\u627E\u5230\u7684\u65E5\u8A18\uFF0C\u88E1\u9762\u5BEB\u8457\u6211\u5728\u5B78\u6821\u88AB\u540C\u5B78\u5011\u9738\u51CC\u7684\u4E8B\u60C5\uFF0C\u8863\u670D\u90FD\u88AB\u4ED6\u5011\u5F04\u5F97\u8D8A\u4F86\u8D8A\u9AD2\uFF0C\u4E5F\u4E00\u6B21\u6BD4\u4E00\u6B21\u9084\u904E\u5206\u3002"
    fullContent: 
    pages:
    - "2004\u5E749\u670830\u65E5\uFF08\u56DB\uFF09 \u4ECA\u5929\u73ED\u4E0A\u7684\u90A3\u7FA4\u5BB6\u4F19\u53C8\u4F86\u627E\u6211\u9EBB\u7169\u3002\u5C31\u56E0\u70BA\u6211\u982D\u9AEE\u7559\u9577\uFF0C\u4E0D\u611B\u8B1B\u8A71\uFF0C\u7E3D\u662F\u4E00\u500B\u4EBA\u5750\u8457\uFF0C\u4ED6\u5011\u5C31\u89BA\u5F97\u6211\u602A\uFF0C\u60F3\u300C\u8A8D\u8B58\u6211\u300D\u3002\u7D50\u679C\u6240\u8B02\u7684\u300C\u8A8D\u8B58\u300D\u5C31\u662F\u62FF\u98F2\u6599\u76F4\u63A5\u5F9E\u6211\u982D\u4E0A\u5012\u4E0B\u4F86\uFF0C\u6700\u5F8C\u5BB3\u5F97\u6211\u6574\u4EF6\u8863\u670D\u90FD\u6FD5\u6389\u4E86\uFF0C\u56DE\u5BB6\u9084\u88AB\u7238\u7238\u7F75\uFF0C\u6211\u8DDF\u4ED6\u89E3\u91CB\uFF0C\u4ED6\u537B\u8AAA\u6211\u81EA\u5DF1\u60F9\u4E8B\u3002 "
    - "2004\u5E7410\u670827\u65E5\uFF08\u4E09\uFF09 \u4ECA\u5929\u6211\u5236\u670D\u88AB\u90A3\u7FA4\u50A2\u4F19\u62FF\u7B46\u8DDF\u7ACB\u53EF\u767D\u5728\u4E0A\u9762\u4E82\u5857\u9D09\uFF0C\u56E0\u70BA\u88AB\u756B\u904E\u7684\u75D5\u8DE1\u6D17\u4E0D\u6389\uFF0C\u6240\u4EE5\u5ABD\u5ABD\u53C8\u5E36\u6211\u53BB\u8CB7\u4E00\u4EF6\u65B0\u7684\uFF0C\u4F46\u5979\u9084\u662F\u4E00\u76F4\u5728\u7F75\u6211\uFF0C\u8AAA\u5E79\u561B\u6C92\u4E8B\u53BB\u62DB\u60F9\u5225\u4EBA\uFF0C\u660E\u660E\u662F\u4ED6\u5011\u6574\u5929\u7121\u804A\u627E\u78B4\uFF0C\u70BA\u4EC0\u9EBC\u932F\u7684\u6C38\u9060\u8B8A\u6210\u662F\u6211\uFF1F\u9019\u7A2E\u65E5\u5B50\u5230\u5E95\u8981\u904E\u5230\u4EC0\u9EBC\u6642\u5019\uFF1F "
    - "2004\u5E7412\u670824\u65E5\uFF08\u4E94\uFF09 \u6211\u7684\u6905\u5B50\u4E0A\u88AB\u4EBA\u5857\u4E86\u5F37\u529B\u81A0\uFF0C\u6211\u5F9E\u5EC1\u6240\u56DE\u4F86\u5F8C\u8932\u5B50\u76F4\u63A5\u88AB\u9ECF\u4F4F\uFF0C\u4ED6\u5011\u8AAA\u770B\u6211\u597D\u50CF\u5F88\u559C\u6B61\u4E00\u76F4\u5750\u5728\u81EA\u5DF1\u7684\u5EA7\u4F4D\u4E0A\u7684\u6A23\u5B50\uFF0C\u6240\u4EE5\u5C31\u5E6B\u6211\u4E00\u628A\uFF0C\u8B93\u6211\u53EF\u4EE5\u8DDF\u6905\u5B50\u6574\u5929\u9ECF\u5728\u4E00\u8D77\uFF0C\u6211\u82B1\u4E86\u597D\u5927\u7684\u529B\u6C23\u624D\u8B93\u8932\u5B50\u8DDF\u6905\u5B50\u5206\u96E2\uFF0C\u4F46\u8932\u5B50\u88AB\u9ECF\u4F4F\u7684\u5730\u65B9\u4E5F\u56E0\u70BA\u904E\u5EA6\u7528\u529B\u7684\u62C9\u626F\u7834\u6389\u4E86\uFF0C\u6211\u90A3\u4E00\u6574\u5929\u5E7E\u4E4E\u90FD\u7A7F\u8457\u7834\u8932\u4E0A\u8AB2\uFF0C\u653E\u5B78\u6211\u9084\u7279\u5730\u7559\u5230\u5B78\u6821\u90FD\u6C92\u6709\u4EBA\u4E4B\u5F8C\u624D\u96E2\u958B\uFF0C\u90A3\u7FA4\u50A2\u4F19\u771F\u7684\u662F\u8D8A\u4F86\u8D8A\u904E\u5206\u4E86\u3002 "
    - "2005\u5E743\u670814\u65E5\uFF08\u4E00\uFF09 \u90A3\u7FA4\u5BB6\u4F19\u5E73\u5E38\u5C31\u6709\u62BD\u83F8\u7684\u7FD2\u6163\uFF0C\u4F46\u4ECA\u5929\u525B\u597D\u88AB\u8001\u5E2B\u6293\u5230\uFF0C\u6240\u6709\u4EBA\u88AB\u8A18\u4E86\u4E00\u652F\u5927\u904E\uFF0C\u4ED6\u5011\u5C31\u628A\u5168\u90E8\u7684\u6C23\u6492\u5728\u6211\u8EAB\u4E0A\uFF0C\u81EA\u5DF1\u62BD\u83F8\u88AB\u6293\u5230\u9084\u4F86\u627E\u6211\u9EBB\u7169\uFF0C\u6211\u771F\u7684\u5FCD\u7121\u53EF\u5FCD\u4E86\uFF0C\u6211\u8A66\u8457\u53CD\u6297\u4ED6\u5011\uFF0C\u4F46\u4ED6\u5011\u4EBA\u591A\u628A\u6211\u67B6\u4F4F\uFF0C\u6211\u5728\u6399\u624E\u7684\u6642\u5019\uFF0C\u4ED6\u5011\u7528\u83F8\u982D\u628A\u6211\u7684\u5916\u5957\u71D9\u7834\uFF0C\u56DE\u5BB6\u5F8C\u5ABD\u5ABD\u8AAA\u5BB6\u88E1\u5DF2\u7D93\u6C92\u9322\u53EF\u4EE5\u8CB7\u65B0\u8863\u670D\u4E86\uFF0C\u53EB\u6211\u81EA\u5DF1\u60F3\u8FA6\u6CD5\uFF0C\u5BB3\u6211\u5F9E\u90A3\u5929\u958B\u59CB\u53EA\u80FD\u6BCF\u5929\u7A7F\u8457\u9019\u4EF6\u7834\u5916\u5957\u53BB\u4E0A\u5B78\u3002 "
    - "2005\u5E745\u670825\u65E5\uFF08\u4E09\uFF09 \u4ECA\u5929\u4E0A\u5B78\u7684\u6642\u5019\uFF0C\u90A3\u7FA4\u5BB6\u4F19\u610F\u5916\u7684\u6C92\u4F86\u627E\u78B4\uFF0C\u539F\u672C\u6211\u60F3\u8AAA\u61C9\u8A72\u662F\u4ED6\u5011\u73A9\u81A9\u4E86\u6216\u662F\u627E\u5230\u5176\u4ED6\u76EE\u6A19\u4E86\uFF0C\u4F46\u6211\u932F\u4E86\uFF0C\u90A3\u5929\u653E\u5B78\u4ED6\u5011\u4E00\u7FA4\u4EBA\u5835\u5728\u6211\u56DE\u5BB6\u7684\u8DEF\u4E0A\uFF0C\u4ED6\u5011\u57CB\u4F0F\u5728\u5DF7\u5B50\u88E1\u5077\u8972\u6211\uFF0C\u4ECA\u5929\u4E2D\u5348\u4E0B\u904E\u96E8\uFF0C\u5730\u677F\u4E0A\u90FD\u662F\u6CE5\u5751\uFF0C\u4ED6\u5011\u628A\u6211\u63A8\u5012\uFF0C\u9084\u4E00\u908A\u5632\u7B11\u6211\u3001\u4E00\u908A\u7528\u8173\u8E29\u6211\uFF0C\u6211\u5C31\u9019\u6A23\u88AB\u5F04\u5F97\u5168\u8EAB\u6CE5\u5DF4\u8DDF\u978B\u5370\uFF0C\u6211\u4ECA\u5929\u53C8\u8981\u81EA\u5DF1\u6D17\u8863\u670D\u4E86\u3002\u9019\u7A2E\u60E1\u5922\u4EC0\u9EBC\u6642\u5019\u624D\u6703\u7D50\u675F\uFF1F "
