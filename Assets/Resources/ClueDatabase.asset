  - id: Journal6
    name: "\u3010\u6728\u5C4B\u88E1\u7684\u65E5\u8A18\u3011"
    detail: "\u4E00\u672C\u8A18\u8F09\u8457\u9670\u5EDF\u4EE5\u53CA\u8A31\u9858\u50B3\u8AAA\u7684\u65E5\u8A18\uFF0C\u65E5\u8A18\u4E3B\u4EBA\u7684\u9858\u671B\u4E5F\u78BA\u5BE6\u5BE6\u73FE\u4E86\uFF0C\u8AAA\u660E\u50B3\u8AAA\u4E26\u4E0D\u662F\u5047\u7684\uFF0C\u4F46\u4F3C\u4E4E\u8981\u652F\u4ED8\u76F8\u61C9\u7684\u4EE3\u50F9\u3002\u65E5\u8A18\u7684\u6700\u5F8C\u537B\u96B1\u96B1\u7D04\u7D04\u8B93\u6211\u89BA\u5F97\u65E5\u8A18\u4E3B\u4EBA\u597D\u50CF\u958B\u59CB\u8B8A\u5F97\u6709\u9EDE\u602A\u602A\u7684\u4E86\u3002"
    fullContent: 
    pages:
    - "1967\u5E7410\u670815\u65E5 \u5B78\u6821\u88E1\u7A81\u7136\u6D41\u50B3\u8457\u4E00\u500B\u50B3\u8AAA\uFF0C\u5B78\u6821\u7684\u5F8C\u5C71\u88E1\u6709\u4E00\u9593\u5EDF\u8A31\u9858\u7279\u5225\u9748\uFF0C\u660E\u5929\u6211\u4E00\u5B9A\u8981\u53BB\u8A66\u8A66\u3002 "
    - "1967\u5E7410\u670816\u65E5 \u6211\u7528\u9ED1\u66DC\u77F3\u624B\u4E32\u5411\u201C\u7942\u201D\u8A31\u9858\uFF0C\u5E0C\u671B\u81EA\u5DF1\u80FD\u8003\u9032\u5168\u6821\u7B2C\u4E00\uFF0C\u5E0C\u671B\u50B3\u8AAA\u662F\u771F\u7684\u3002 "
    - "1967\u5E7410\u670829\u65E5 \u6700\u8FD1\uFF0C\u773C\u775B\u6709\u9EDE\u770B\u4E0D\u6E05\u6771\u897F\u4E86\uFF0C\u4E4B\u5F8C\u8981\u627E\u6642\u9593\u53BB\u63DB\u526F\u773C\u93E1\u4E86\u3002 "
    - "1967\u5E7410\u670830\u65E5 \u50B3\u8AAA\u662F\u771F\u7684\uFF01\u6211\u771F\u7684\u8003\u9032\u5168\u6821\u7B2C\u4E00\u4E86\uFF0C\u4F46\u4E0D\u77E5\u9053\u70BA\u4EC0\u9EBC\u6700\u8FD1\u611F\u89BA\u8EAB\u9AD4\u4E0D\u807D\u4F7F\u559A\uFF0C\u53EF\u80FD\u662F\u6700\u8FD1\u90FD\u5728\u71AC\u591C\u5099\u8003\uFF0C\u6C92\u597D\u597D\u4F11\u606F\u5427\u3002 "
    - "1967\u5E7411\u670801\u65E5 \u70BA\u4EC0\u9EBC\u81C9\u4E0A\u958B\u59CB\u6709\u985E\u4F3C\u5080\u5121\u7684\u75D5\u8DE1\uFF1F\u8A72\u4E0D\u6703\u662F\u8A31\u9858\u7684\u4EE3\u50F9\uFF1F\u600E\u9EBC\u53EF\u80FD\u2026\u5982\u679C\u6709\u9019\u6A23\u7684\u4EE3\u50F9\uFF0C\u90A3\u8981\u600E\u9EBC\u8B49\u660E\u50B3\u8AAA\u9084\u80FD\u50B3\u64AD\u5728\u5B78\u6821\u5462\uFF0C\u6211\u4E4B\u5F8C\u4E00\u5B9A\u9084\u8981\u518D\u627E\u6642\u9593\u53BB\u90A3\u88E1\u8A31\u9858\u300D "
    collected: 0
    collectedTime: 0
  - id: note1
    name: "\u3010\u67D0\u4EBA\u907A\u7559\u7684\u7D19\u689D\u3011"
    detail: "\u611F\u89BA\u6028\u5FF5\u6975\u6DF1\u7684\u7D19\u689D\uFF0C\u4E0A\u9762\u6EFF\u6EFF\u7684\u90FD\u662F\u61CA\u6094\u8DDF\u61A4\u6012\uFF0C\u4EE5\u53CA\u90A3\u91CD\u8907\u597D\u5E7E\u6B21\u7684\u300E\u6211\u4E0D\u8981\u8B8A\u6210\u5080\u5121\u300F\u3002\u770B\u4F86\u5BEB\u9019\u5F35\u7D19\u689D\u7684\u4EBA\u61C9\u8A72\u51F6\u591A\u5409\u5C11\u4E86\u3002"
    fullContent: 
    pages: []
    collected: 0
    collectedTime: 0
  - id: note2
    name: "\u3010\u5B78\u9577\u7684\u7D19\u689D\u3011"
    detail: "\u4E00\u5F35\u5B78\u9577\u907A\u7559\u7684\u7D19\u689D\uFF0C\u4E0A\u9762\u5BEB\u8457\u4ED6\u7684\u9053\u6B49\u4EE5\u53CA\u61CA\u6094\uFF0C\u4ED6\u70BA\u4E86\u518D\u8A31\u4E00\u500B\u9858\u671B\uFF0C\u5E6B\u201C\u5B83\u201D\u6563\u64AD\u50B3\u8AAA\u3002\u4ED6\u4E0D\u53EA\u662F\u53D7\u5BB3\u8005\uFF0C\u9084\u6210\u4E86\u5E6B\u5147\u3002"
    fullContent: "\u300C\u5C0D\u4E0D\u8D77\uFF0C\u6211\u4E0D\u8A72\u5354\u52A9\u50B3\u8AAA\u7684\u50B3\u64AD\u3002\u50B3\u8AAA\u6703\u5EE3\u6CDB\u6D41\u50B3\u662F\u56E0\u70BA\u6211\u807D\u4FE1\u7942\u7684\u8A71\uFF0C\u7942\u8AAA\u53EA\u8981\u628A\u50B3\u8AAA\u6563\u64AD\u51FA\u53BB\uFF0C\u5C31\u518D\u5BE6\u73FE\u6211\u4E00\u500B\u9858\u671B\uFF0C\u9084\u8B93\u6211\u8B8A\u56DE\u6B63\u5E38\u7684\u6A23\u5B50\u3002\u6211\u771F\u7684\u4E0D\u77E5\u9053\u4E00\u5207\u6703\u8B8A\u6210\u9019\u6A23\u2026\u2026\u5E0C\u671B\u6709\u4EBA\u53EF\u4EE5\u963B\u6B62\u7942\u3002\u7942\u7684\u8A71\u5343\u842C\u4E0D\u80FD\u4FE1\uFF0C\u7942\u6839\u672C\u53EA\u662F\u5728\u5229\u7528\u4EBA\uFF0C\u4E5F\u4E0D\u6703\u5E6B\u6211\u5BE6\u73FE\u3002\u300D"
    pages: []
    collected: 0
    collectedTime: 0
  - id: recorder
    name: "\u3010\u5B78\u59CA\u7684\u9304\u97F3\u5E36\u3011"
    detail: "\u88E1\u9762\u64AD\u653E\u8457\u4E00\u6BB5\u722D\u57F7\u8072\uFF0C\u6709\u500B\u5973\u751F\u63A7\u8A34\u201C\u5B83\u201D\u6B3A\u9A19\u4E86\u81EA\u5DF1\uFF0C\u96D6\u7136\u9858\u671B\u5BE6\u73FE\u4E86\uFF0C\u4F46\u5B8C\u5168\u4E0D\u662F\u81EA\u5DF1\u60F3\u8981\u7684\uFF0C\u800C\u201C\u5B83\u201D\u537B\u53EA\u662F\u51B7\u51B7\u7684\u5632\u8AF7\u8457\u90A3\u500B\u4F86\u8A31\u9858\u7684\u4EBA\u3002\u770B\u6A23\u5B50\u9858\u671B\u5BE6\u73FE\u4E5F\u4E0D\u4E00\u5B9A\u662F\u597D\u4E8B\u3002\n\u88E1\u9762\u9084\u64AD\u653E\u4E86\u4E00\u500B\u5973\u751F\u6240\u5531\u7684\u53F0\u8A9E\u7AE5\u8B20\u3002"
    fullContent: 
    pages:
    - "\u5973\u8072\uFF1A\u300C\u4F60\u9A19\u6211\uFF01\u6211\u53EA\u662F\u8A31\u4E86\u500B\u9858\uFF0C\u5E0C\u671B\u80FD\u5728\u5B78\u6821\u88E1\u51FA\u540D\uFF0C\u70BA\u4EC0\u9EBC\u8981\u628A\u6211\u56F0\u5728\u9019\u500B\u9B3C\u5730\u65B9\uFF1F\uFF01\u300D
      \uFF1F\uFF1F\uFF1A\u300C\u9A19\u59B3\uFF1F\u6211\u60F3\u59B3\u8AA4\u6703\uFF0C\u6211\u53EA\u662F\u5BE6\u73FE\u4E86\u59B3\u7684\u9858\u671B\u800C\u5DF2\u3002\u59B3\u5931\u8E64\u7684\u6D88\u606F\u5728\u6821\u5712\u88E1\u50B3\u5F97\u6CB8\u6CB8\u63DA\u63DA\uFF0C\u73FE\u5728\u5168\u6821\u4E0A\u4E0B\u6C92\u6709\u4EBA\u4E0D\u77E5\u9053\u59B3\u7684\u540D\u5B57\u3002\u9019\u4E0D\u5C31\u662F\u59B3\u60F3\u8981\u7684\u55CE\uFF1F\u300D
      \u5973\u8072\uFF1A\u300C\u9019\u4E0D\u662F\u6211\u60F3\u8981\u7684\u65B9\u5F0F\uFF01\u6211\u60F3\u9760\u81EA\u5DF1\u7684\u52AA\u529B\u3001\u624D\u83EF\u3001\u8868\u73FE\u2026\u4E0D\u662F\u9760\u5931\u8E64\u3001\u4E0D\u662F\u9760\u6050\u61FC\uFF01\u300D
      \uFF1F\uFF1F\uFF1A\u300C\u90A3\u53EA\u662F\u59B3\u7684\u5E7B\u60F3\u7F77\u4E86\u3002\u59B3\u4EE5\u70BA\u540D\u8072\u4E0D\u9700\u8981\u4EE3\u50F9\uFF1F\u59B3\u4EE5\u70BA\u9858\u671B\u53EF\u4EE5\u4E0D\u7D93\u601D\u8003\u5730\u8A31\u4E0B\uFF0C\u7136\u5F8C\u5C31\u80FD\u6BEB\u7121\u4EE3\u50F9\u5730\u5BE6\u73FE\uFF1F\u300D
      \u5973\u8072\uFF1A\u300C\u6211\u2026\u6211\u53EA\u662F\u592A\u6E34\u671B\u88AB\u770B\u898B\u4E86\u2026\u300D
      \uFF1F\uFF1F\uFF1A\u300C\u6E34\u671B\uFF1F\u4E0D\uFF0C\u662F\u8CAA\u5A6A\u3002\u59B3\u9078\u64C7\u76F8\u4FE1\u4E00\u500B\u4F86\u8DEF\u4E0D\u660E\u7684\u50B3\u8AAA\uFF0C\u9078\u64C7\u5411\u6211\u8A31\u9858\u3002\u6211\u53EF\u6C92\u903C\u59B3\uFF0C\u662F\u59B3\u81EA\u5DF1\u8D70\u9032\u4F86\u7684\u300D
      \u5973\u8072\uFF1A\u300C\u6211\u5F8C\u6094\u4E86\u2026\u300D \uFF1F\uFF1F\uFF1A\u300C\u5F8C\u6094\uFF1F\u592A\u9072\u4E86\u3002\u9858\u671B\u5DF2\u7D93\u514C\u73FE\uFF0C\u4EE3\u50F9\u4E5F\u5DF2\u7D93\u958B\u59CB\u6536\u53D6\u3002\u59B3\u60F3\u9003\uFF1F\u90A3\u5C31\u5F97\u4ED8\u51FA\u66F4\u591A......\u300D "
    - "\u56DB\u76EE\u7AE5\uFF0C\u56DB\u76EE\u7AE5\uFF0C \u9ED1\u9762\u7D05\u76EE\u5750\u5C71\u7A97\u3002 
      \u4E00\u76EE\u671B\u5C71\u8DEF\uFF0C \u4E00\u76EE\u807D\u5FC3\u98A8\u3002 \u5169\u76EE\u85CF\u6697\u6D1E\uFF0C
      \u5FC3\u4E8B\u8B1B\u8882\u901A\u3002 \u56DB\u76EE\u7AE5\uFF0C\u56DB\u76EE\u7AE5\uFF0C
      \u53EB\u4F60\u83AB\u53BB\u4E82\u76F8\u9022\u3002  \u4E00\u53E5\u9858\u671B\u8B1B\uFF0C
      \u4E00\u53E5\u5F71\u4ED4\u5171\uFF0C \u77F3\u76EE\u82E5\u9583\u5149\uFF0C \u9B42\u8DEF\u6B79\u8FD4\u5DE5\u3002"
